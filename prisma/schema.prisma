// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id         Int       @id @default(autoincrement())
  cardnumber String    @unique
  firstname  String
  surname    String
  email      String?
  emailpro   String?
  vehicles   Vehicle[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Vehicle {
  id           Int       @id @default(autoincrement())
  plate        String    @unique
  brand        String?
  model        String
  color        String
  icon         String
  department   String
  status       String
  registeredAt DateTime  @default(now())
  
  ownerId      Int?
  owner        Student?  @relation(fields: [ownerId], references: [id])
}

model AccessRequest {
  id            Int      @id @default(autoincrement())
  requesterName String
  plateNumber   String
  visitDate     DateTime
  reason        String
  status        String   // PENDING, APPROVED, EXPIRED
  createdAt     DateTime @default(now())
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  plate     String
  userType  String
  zone      String
  status    Boolean  // true = GRANTED, false = REJECTED
}

model UserRegistration {
  id                Int      @id @default(autoincrement())
  userType          String   // ESTUDIANTE, ADMINISTRATIVO, DOCENTE
  email             String
  institutionalCode String
  fullName          String
  carnetFilePath    String
  ownershipFilePath String
  plate             String
  vehicleBrand      String?
  vehicleModel      String?
  status            String   @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  createdAt         DateTime @default(now())
}
